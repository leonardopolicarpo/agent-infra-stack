# ── Postgres ───────────────────────────────────────
POSTGRES_USER=agent
POSTGRES_PASSWORD=agent_pass
POSTGRES_DB=agent_db

# ── Langfuse ───────────────────────────────────────
# openssl rand -hex 32
LANGFUSE_SECRET=supersecretkey_change_in_prod
LANGFUSE_SALT=saltsaltsalt_change_in_prod

# ── Modelos Ollama ─────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
ROUTER_MODEL=llama3.2:3b
TASK_MODEL=llama3.2:3b